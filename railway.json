{\n  "$schema": "https://railway.com/railway.schema.json",\n  "build": {\n    "builder": "DOCKERFILE",\n    "dockerfilePath": "Dockerfile"\n  },\n  "deploy": {\n    "startCommand": "python manage.py makemigrations tenants billing zatca accounting sales inventory hr pos ai --noinput && python manage.py migrate_schemas --shared && python manage.py migrate_schemas && python manage.py collectstatic --noinput && daphne -b 0.0.0.0 -p $PORT erp_system.asgi:application",\n    "healthcheckPath": "/health/",\n    "healthcheckTimeout": 120,\n    "restartPolicyType": "ON_FAILURE",\n    "restartPolicyMaxRetries": 3\n  }\n}